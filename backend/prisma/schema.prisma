generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String @id @default(uuid()) @unique
  name  String
  role  String @default("USER")
  email String @unique
  profilePic String?
  refreshToken String?
  isVerified Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  submissions Submission[]

  accounts AuthAccount[]
}

model AuthAccount {
  provider AuthProvider
  email String @unique
  providerId String
  user User @relation(fields: [userId], references: [id])
  userId String

  @@unique([provider, providerId])
}

model Submission {
  id String @id @default(uuid()) @unique
  title String
  questionId String
  language Language
  time String
  memory String
  status SubmissionStatus
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user User @relation(fields: [userId], references: [id])
  userId String
}


enum Language {
  PYTHON
  JAVASCRIPT
  C
  CPP
  JAVA
}

enum SubmissionStatus {
  PENDING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  RUNTIME_ERROR
  COMPILATION_ERROR
}

enum AuthProvider {
  GOOGLE
  GITHUB
}